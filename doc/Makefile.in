LIBUSB_SRC_DIR = @top_srcdir@/libusb
EXCLUDED_FILES = libusbi.h version.h version_nano.h
LIBUSB_SRC = $(wildcard $(LIBUSB_SRC_DIR)/*.c) $(wildcard $(LIBUSB_SRC_DIR)/*.h)
LIBUSB_DOC_SRC = $(filter-out $(addprefix $(LIBUSB_SRC_DIR)/,$(EXCLUDED_FILES)),$(LIBUSB_SRC))

DOXYGEN = @DOXYGEN@
GENERATE_MAN = @GENERATE_MAN@
prefix = @prefix@
datarootdir = @datarootdir@
mandir = @mandir@
INSTALL = @INSTALL@
INSTALL_DATA = @INSTALL_DATA@
MKDIR_P = @MKDIR_P@
DESTDIR =

docs: @DOXYGEN_HTMLDIR@

@DOXYGEN_HTMLDIR@: doxygen.cfg @top_srcdir@/doc/libusb.png $(LIBUSB_DOC_SRC)
	$(DOXYGEN) $<

# Man pages are generated by the same doxygen invocation as HTML docs
man: @DOXYGEN_HTMLDIR@

install-man: man
	@if test "x$(GENERATE_MAN)" = xYES && test -d man/man3; then \
		echo "Installing man pages to $(DESTDIR)$(mandir)/man3"; \
		$(MKDIR_P) $(DESTDIR)$(mandir)/man3; \
		for f in man/man3/*.3; do \
			$(INSTALL_DATA) "$$f" "$(DESTDIR)$(mandir)/man3/"; \
		done; \
	fi

uninstall-man:
	@if test -d man/man3; then \
		for f in man/man3/*.3; do \
			rm -f "$(DESTDIR)$(mandir)/man3/$$(basename $$f)"; \
		done; \
	fi

sfurl = web.sourceforge.net:/home/project-web/libusb/htdocs
docs-upload: @DOXYGEN_HTMLDIR@
	if [ -z "$$SF_USER" ]; then \
		rsync -rv --delete $< $(sfurl); \
	else \
		rsync -rv --delete $< $$SF_USER@$(sfurl); \
	fi

clean:
	rm -rf @DOXYGEN_HTMLDIR@ man

.PHONY: clean docs docs-upload man install-man uninstall-man
